# ==============================================================================
# .env.example - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains secrets
#
# For Render deployment:
#   1. Copy each variable name from this file
#   2. Set actual values in Render dashboard → Environment
#   3. Do NOT upload .env file to GitHub
#
# For local development:
#   1. Copy to .env
#   2. Fill in with local values
#   3. Load with: from dotenv import load_dotenv; load_dotenv()
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================
DEBUG=false
APP_NAME=Solar Equipment Intelligence Engine
APP_VERSION=1.0.0

# ==============================================================================
# DATABASE - PostgreSQL
# ==============================================================================
# Format: postgresql://user:password@host:port/database
# Render example: postgresql://seuser:xxxxx@dpg-xxxxx.render-instances.com:5432/sedb
# Local example: postgresql://postgres:password@localhost:5432/specsheet_engine
DATABASE_URL=postgresql://user:password@localhost:5432/specsheet_engine

# ==============================================================================
# REDIS CACHE
# ==============================================================================
# Format: redis://[:password@]host[:port][/db]
# Render example: redis://red-xxxxx:password@render-redis.render.com:6379
# Local example: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=86400

# ==============================================================================
# GOOGLE GEMINI API
# ==============================================================================
# Get key from: https://aistudio.google.com/app/apikey
# Required for spec extraction
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_REPAIR_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-1.5-flash
GEMINI_INTERNET_SEARCH_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.0

# ==============================================================================
# SERPER API (Search)
# ==============================================================================
# Get key from: https://serper.dev
# Optional but recommended for source discovery
SERPER_API_KEY=your_serper_api_key_here
SERPER_MAX_RESULTS=5
SERPER_CREDIT_WARNING_THRESHOLD=100
SERPER_CREDIT_CRITICAL_THRESHOLD=10

# ==============================================================================
# AWS S3 STORAGE
# ==============================================================================
# For cached PDF storage
# Get from AWS IAM console
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_ENDPOINT=sjc1.vultrobjects.com
AWS_S3_REGION=sjc1
AWS_S3_BUCKET=test1

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
ENABLE_SERPER_SOURCE_SEARCH=true
ENABLE_GROUNDED_WEB_FALLBACK=true

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
TARGET_COUNTRY=US
MIN_TRUST_SCORE=50
MIN_MATCH_SCORE=80.0
MIN_CONFIDENCE_SCORE=0.60

# ==============================================================================
# CELERY WORKERS (Background Tasks)
# ==============================================================================
# Same as Redis URLs unless using different instances
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
